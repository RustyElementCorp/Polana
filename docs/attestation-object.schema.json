{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polana.dev/schema/attestation-object.schema.json",
  "title": "Polana Attestation Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "attestation_id",
    "subject_id",
    "subject_type",
    "kind",
    "issuer",
    "evidence",
    "status",
    "timestamps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "attestation_id": {
      "type": "string",
      "pattern": "^att_[a-z0-9]+$"
    },
    "subject_id": {
      "type": "string",
      "pattern": "^(mem_[a-z0-9_-]{16,}|bind_[a-z0-9]+|prod_[a-z0-9]+|own_[a-z0-9]+|att_[a-z0-9]+|anch_[a-z0-9]+)$"
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "memory",
        "binding",
        "producer",
        "owner",
        "attestation",
        "anchor"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "producer_signature",
        "human_review",
        "enterprise_approval",
        "execution_proof",
        "compliance_check",
        "binding_verification",
        "anchor_confirmation"
      ]
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer_id",
        "issuer_type"
      ],
      "properties": {
        "issuer_id": {
          "type": "string",
          "pattern": "^(prod|own)_[a-z0-9]+$"
        },
        "issuer_type": {
          "type": "string",
          "enum": [
            "producer",
            "owner"
          ]
        },
        "display_name": {
          "type": "string",
          "maxLength": 128
        },
        "key_ref": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "value": {
          "type": "string",
          "maxLength": 4096
        },
        "ref": {
          "type": "string",
          "maxLength": 256
        },
        "hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64,128}$"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "issued",
        "revoked"
      ]
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued_at"
      ],
      "properties": {
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "revoked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 512
    }
  }
}
