{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polana.dev/schema/binding-object.schema.json",
  "title": "Polana Binding Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "subject_id",
    "subject_type",
    "external_ref",
    "verification",
    "timestamps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "binding_id": {
      "type": "string",
      "pattern": "^bind_[a-z0-9]+$"
    },
    "subject_id": {
      "type": "string",
      "pattern": "^(prod|own|att|anch)_[a-z0-9]+$"
    },
    "subject_type": {
      "type": "string",
      "enum": [
        "producer",
        "owner",
        "attestation",
        "anchor"
      ]
    },
    "external_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network",
        "address",
        "scheme"
      ],
      "properties": {
        "network": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "address": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "scheme": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "method"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "claimed",
            "verified",
            "revoked"
          ]
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "evidence_ref": {
          "type": "string",
          "maxLength": 256
        },
        "verified_by": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "revoked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "notes": {
      "type": "string",
      "maxLength": 512
    }
  }
}
