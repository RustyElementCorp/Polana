    "demo:verify": "node ./apps/demo-cli/dist/index.js verify",
    "api:start": "node ./apps/ingestion-api/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
